# Neon Postgres (required)
DATABASE_URL="postgresql://user:pass@host:5432/dbname?sslmode=require"

# Auth.js (required for production)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-string-min-32-chars-for-production"

# Optional: change the bootstrap password used on first admin login after seed
# ADMIN_INITIAL_PASSWORD="mpp2026"
